{
  "name": "live-location-tracker",
  "version": "1.0.0",
  "description": "Real-time authenticated live location tracker using Socket.IO, Kafka, OIDC/OAuth 2.0, and Leaflet.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "kafka:setup": "node src/kafka-admin.js",
    "dev": "node src/server.js",
    "processor": "node src/database-processor.js",
    "start": "node src/server.js"
  },
  "keywords": [
    "socket.io",
    "kafka",
    "oidc",
    "oauth2",
    "leaflet",
    "location-tracking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {}
}
